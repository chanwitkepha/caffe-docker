# ======================
# CUDA
# ======================
CUDA_DIR := /usr/local/cuda

CUDA_ARCH := \
    -gencode arch=compute_86,code=sm_86 \
    -gencode arch=compute_89,code=sm_89 \
    -gencode arch=compute_89,code=compute_89

USE_CUDNN := 0
USE_NCCL := 0

# ======================
# BLAS
# ======================
BLAS := open

# ======================
# Python / pycaffe
# ======================
# เปิด Python layer (จำเป็นสำหรับ pycaffe)
WITH_PYTHON_LAYER := 1

# Python 3.10 (Ubuntu 22.04)
PYTHON_INCLUDE := /usr/include/python3.10 \
                  /usr/lib/python3/dist-packages/numpy/core/include

PYTHON_LIB := /usr/lib

# ต้องลิงก์ boost-python + python runtime
# (ชื่อ boost_python310 ถูกต้องสำหรับ Ubuntu 22.04)
PYTHON_LIBRARIES := boost_python310 python3.10

# ======================
# OpenCV / HDF5
# ======================
# Caffe เก่าทำงานกับ OpenCV4 ได้ดีสุดเมื่อบอกว่าเป็น branch 3
OPENCV_VERSION := 3

USE_HDF5 := 1

# ======================
# Include / Library paths
# ======================
INCLUDE_DIRS := $(PYTHON_INCLUDE) \
                /usr/local/include \
                /usr/include/opencv4 \
                /usr/include/hdf5/serial

LIBRARY_DIRS := $(PYTHON_LIB) \
                /usr/local/lib \
                /usr/lib \
                /usr/lib/x86_64-linux-gnu \
                /usr/lib/x86_64-linux-gnu/hdf5/serial

# OpenCV imgcodecs (จำเป็นสำหรับ imread/imdecode/imencode)
LIBRARIES += opencv_imgcodecs

# ======================
# Build
# ======================
BUILD_DIR := build
DISTRIBUTE_DIR := distribute
TEST_GPUID := 0

Q ?= @
``
